url_raw <- "https://raw.githubusercontent.com/EEOB-BioData/BCB546_Spring2024/main/assignments/UNIX_Assignment/fang_et_al_genotypes.txt"
fang <- read.delim(url_raw, header = TRUE, sep = "\t", quote = "")
url_raw2 <-"https://raw.githubusercontent.com/EEOB-BioData/BCB546_Spring2024/main/assignments/UNIX_Assignment/snp_position.txt"
snp <- read.delim(url_raw2, header = TRUE, sep = "\t", quote = "")
library(dplyr)
t_fang <- t(fang)
fang_group <- t_fang[c(1:3),] %>% as.data.frame()
fang_data <- t_fang[-c(1:3),] %>% as.data.frame()
fang_data$SNP_ID <- rownames(fang_data)
merge <- dplyr::inner_join(snp, fang_data, by = "SNP_ID")
merge_group <- bind_rows(fang_group, merge) %>% t() %>% as.data.frame()
maize_group <- merge_group %>%
dplyr::filter(Group %in% c("ZMMIL", "ZMMLR", "ZMMMR")) %>%
rbind(merge_group[c("Chromosome","Position"),]) %>%
t() %>%
as.data.frame()
maize_group <- filter(maize_group, Chromosome != "multiple" & Chromosome != "unknown")
teosinte_group <- merge_group %>%
dplyr::filter(Group %in% c("ZMPBA", "ZMPIL", "ZMPJA")) %>%
rbind(merge_group[c("Chromosome","Position"),]) %>%
t() %>%
as.data.frame()
teosinte_group <- filter(teosinte_group, Chromosome != "multiple" & Chromosome != "unknown")
exists("merge_group")
merge_vis <- merge_group %>% t() %>% as.data.frame() %>% mutate(Chromosome = as.character(Chromosome), Position = as.numeric(as.character(Position))) known_chromosomes <- as.character(1:10)
merge_vis <- merge_group %>% t() %>% as.data.frame() %>% mutate(Chromosome = as.character(Chromosome), Position = as.numeric(as.character(Position)))
known_chromosomes <- as.character(1:10)
p0 <- merge_vis %>% count(Chromosome) %>% ggplot(data = ., mapping = aes(x = Chromosome, y = n)) + geom_bar(stat = "identity") + labs (title = "SNP Distribution", x = "Chromosome", y = "Number of SNPs") + theme_minimal()
p1 <- merge_vis %>% filter(Chromosome %in% known_chromosomes) %>% ggplot(data = ., mapping = aes(x = Position, fill = Chromosome)) + geom_density(alpha = 0.4) + facet_wrap(~ Chromosome, nrow = 2, ncol = 5) + labs(title = "SNP Position Distribution", x = "Position", y = "Density") + theme_minimal() + theme(axis.text.x = element_text(angle = 45, hjust = 1))
p2 <- maize_group %>% count(Chromosome) %>% ggplot(data = ., mapping = aes(x = Chromosome, y = n)) + geom_bar(stat = "identity") + labs(title = "Maize - SNP Distribution", x = "Chromosome", y = "Number of SNPs") + theme_minimal()
p3 <- teosinte_group %>% count(Chromosome) %>% ggplot(data = ., mapping = aes(x = Chromosome, y = n)) + geom_bar(stat = "identity") + labs(title = "Teosinte - SNP Distribution", x = "Chromosome", y = "Number of SNPs") + theme_minimal()
