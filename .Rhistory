merge_group_long <- merge_group %>% pivot_longer (cols = starts_with("..."), names_to = "SNP", values_to = "Genotype") %>% mutate(State = case_when (Genotype %in% c("A/A", "C/C", "G/G", "T/T") ~ "Homozygous", Genotype %in% c("?/A", "?/C", "?/G", "?/T", "A/?", "C/?", "G/?", "T/?", "?/?") ~ "Missing", TRUE ~ "Heterozygous"))
head(merge_group_long)
p4 <- ggplot(data = merge_group_long, mapping = aes(x = State, fill = State)) + geom_bar(position = "fill") + labs(title = "Overall Proportion of Homozygous, Heterozygous, and Missing Data", x = "Genotype state", y = "Proportion") + theme_minimal()
p5 <- ggplot(data = merge_group_long, mapping = aes(x = Sample_ID, fill = State)) + geom_bar(position = "fill") + labs(title ="Proportion of Homozygous, Heterozygous, and Missing Data by Sample", x = "Sample", y = "Proportion") + theme_minimal() + theme(axis.text.x = element_blank())
p6 <- ggplot(data = merge_group_long, mapping = aes(x = Group, fill = State)) + geom_bar(position = "fill") + labs(title = "Proportion of Homozygous, Heterozygous, and Missing Data by Group", x = "Group", y = "Proportion") + theme_minimal() + theme(axis.text.x = element_text(angle = 45, hjust = 1))
p4
p5
p6
pdf("Homozygous_Visualization_Shamima.pdf")
print(p4)
print(p5)
print(p6)
dev.off()
